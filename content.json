      "order": 2,
      "fields": {
        "headline": "Zemné a výkopové práce",
        "subheadline": "Profesionálne služby v okresoch Prešov a Sabinov s modernou technikou a dlhoročnými skúsenosťami.",
        "cta_text": "Kontaktujte nás",
