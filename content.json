    {
      "type": "testimonials",
      "id": "testimonials_1",
      "label": "Recenzie",
      "order": 9,
      "fields": {
        "headline": "Čo hovoria naši klienti",
        "subtitle": "Dôvera našich zákazníkov je pre nás najdôležitejšia",
        "items": [
          {
            "id": "rev_1",
            "name": "Jozef",
            "text": "Kvalitne odvedená práca, profesionálny prístup bagristu. Bager flexibilný, dostane sa skoro všade. Spokojnosť. Cena adekvátna k dobre odvedenej práci.",
            "role": "Renčišov",
            "rating": 5
          },
          {
            "id": "rev_2",
            "name": "Martin",
            "text": "Rýchla a spoľahlivá práca. Damián bol veľmi ochotný a profesionálny. Výkopy pre náš rodinný dom boli hotové v rekordnom čase. Určite odporúčam!",
            "role": "Sabinov",
            "rating": 5
          },
          {
            "id": "rev_3",
            "name": "Peter",
            "text": "Veľmi dobrá spolupráca. Presný termín, kvalitná práca a férová cena. Stroj sa dostal aj do miest, kde som to nečakal. Ďakujem za pomoc s kanalizáciou.",
            "role": "Prešov",
            "rating": 5
          }
        ]
      }
    },
