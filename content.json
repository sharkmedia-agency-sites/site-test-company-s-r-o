    {
      "type": "cta_banner",
      "id": "cta_1",
      "label": "Výzva k akcii",
      "order": 8,
      "fields": {
        "headline": "Nové stroje, lepšie výsledky",
        "text": "Investovali sme do novej modernej techniky, aby sme vám mohli poskytnúť ešte kvalitnejšie a rýchlejšie služby. Kontaktujte nás a presvedčte sa sami o kvalite našej práce.",
