    },
    {
      "type": "about",
      "id": "about_1",
      "label": "O nás",
      "order": 3,
      "fields": {
        "headline": "O nás",
        "subtitle": "Prečo si vybrať práve nás",
        "text": "Sme rodinná firma so sídlom v Sabinove, ktorá sa špecializuje na zemné a výkopové práce. S našimi modernými strojmi a profesionálnym prístupom zabezpečíme kvalitné výsledky pre každý projekt. Disponujeme novými strojmi a neustále investujeme do modernej techniky, aby sme vám poskytli tie najlepšie služby.",
        "text_2": "Naše služby pokrývajú široké okolie vrátane okresov Prešov, Sabinov a priľahlých oblastí. Či už potrebujete výkopy pre základy, inžinierske siete alebo terénne úpravy — sme tu pre vás.",
        "image": "images/about_section.png",
        "experience_years": "5+",
        "experience_label": "rokov skúseností"
      }
    },
    {
      "type": "services_grid",
      "id": "services_1",
      "label": "Naše služby",
      "order": 4,
      "fields": {
        "headline": "Naše služby",
        "subtitle": "Komplexné riešenia pre vaše projekty",
        "items": [
          {
            "id": "svc_1",
            "title": "Výkopy pre základy",
            "description": "Realizujeme výkopy pre rodinné domy, garáže a ďalšie stavby. Presná práca s moderným rýpadlom Kubota zaistí kvalitný základ vášho projektu.",
            "icon": "foundation",
            "image": "images/service_foundations.png"
          },
          {
            "id": "svc_2",
            "title": "Inžinierske siete",
            "description": "Kopeme výkopy pre vodovod, kanalizáciu, plyn a elektrické vedenie. Disponujeme lopatami rôznych šírok od 30cm do 60cm.",
            "icon": "pipe",
            "image": "images/service_utilities.png"
          },
          {
            "id": "svc_3",
            "title": "Terénne úpravy",
            "description": "Svahovanie, vyrovnávanie terénu a príprava stavebných pozemkov. S hydraulickou svahovacou lyžicou 120cm dosiahneme ideálny výsledok.",
            "icon": "terrain",
            "image": "images/service_terrain.png"
          },
          {
            "id": "svc_4",
            "title": "Búracie práce",
            "description": "Demolácie menších stavieb, búranie betónových plôch a odstraňovanie starých konštrukcií s odborným prístupom.",
            "icon": "demolition",
            "image": "images/service_demolition.png"
          },
          {
            "id": "svc_5",
            "title": "Odvoz zeminy",
            "description": "Zabezpečíme odvoz vykopanej zeminy a stavebného odpadu. Komplexné riešenie od výkopu po čistý pozemok.",
            "icon": "truck",
            "image": "images/service_transport.png"
          },
          {
            "id": "svc_6",
            "title": "Špeciálne práce",
            "description": "Výkopy v stiesnených priestoroch vďaka nulovému presahu rýpadla. Mimoosové kopanie pre prácu blízko budov a plotov.",
            "icon": "precision",
            "image": "images/service_special.png"
          }
        ]
      }
    },
    {
