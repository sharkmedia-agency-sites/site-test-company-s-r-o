          { "id": "spec_3", "label": "Objem lyžice", "value": "66 l" },
          { "id": "spec_4", "label": "Zarovnávacia radlica", "value": "1500 x 300 mm" },
          { "id": "spec_5", "label": "Dĺžka stroja", "value": "4 190 mm" },
          { "id": "spec_6", "label": "Výška stroja", "value": "2 430 mm" },
          { "id": "spec_7", "label": "Šírka stroja", "value": "1 560 mm" }
        ],
        "accessories": [
          { "id": "acc_1", "title": "Lopata 30cm", "description": "Pre úzke výkopy a inžinierske siete", "icon": "shovel" },
          { "id": "acc_2", "title": "Lopata 50cm", "description": "Štandardná šírka pre väčšinu prác", "icon": "shovel" },
          { "id": "acc_3", "title": "Lopata 60cm", "description": "Pre širšie výkopy a základy", "icon": "shovel" },
          { "id": "acc_4", "title": "Svahovacia lyžica 120cm", "description": "Hydraulická lyžica pre terénne úpravy", "icon": "level" }
        ]
