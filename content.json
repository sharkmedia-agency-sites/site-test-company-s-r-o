        "machine_name": "Kubota U27-4",
        "machine_description": "Pásové rýpadlo s hmotnosťou 2700 kg, nulovým presahom a možnosťou mimoosového kopania. Ideálne pre prácu v stiesnených priestoroch a blízko existujúcich stavieb.",
        "machine_image": "images/machine_kubota.png",
        "specs": [
          { "id": "spec_1", "label": "Prevádzková hmotnosť", "value": "2 590 kg" },
